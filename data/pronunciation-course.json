{
  "meta": {
    "title": "Как читаются французские буквосочетания",
    "contentVersion": "2.2.0",
    "dailyMinutes": "8-12",
    "method": "короткое сочетание → звук → слово → несколько слов",
    "cardMethod": "одна атомарная карточка = одно написание в одном контексте",
    "sourceNote": "Тренажёр построен по пользовательскому гайду и учит переводить написание в звучание. Постановка отдельных звуков в этот курс не входит."
  },
  "sources": [
    {
      "name": "Пользовательский гайд «Правила французского произношения»",
      "note": "Единственный источник тем курса: буквосочетания, позиционные правила, окончания и стыки слов."
    }
  ],
  "modules": [
    {
      "id": "short-patterns",
      "order": 1,
      "title": "Короткие сочетания",
      "description": "Начинаем с устойчивых гласных и согласных сочетаний длиной в одну–три буквы."
    },
    {
      "id": "context-rules",
      "order": 2,
      "title": "Звук зависит от соседей",
      "description": "Учимся смотреть на следующую букву и отличать обычное правило от исключения."
    },
    {
      "id": "nasal-patterns",
      "order": 3,
      "title": "Носовые сочетания",
      "description": "Читаем an, on, in и видим случаи, когда n или m снова произносится отдельно."
    },
    {
      "id": "words-and-flow",
      "order": 4,
      "title": "Слова и стыки слов",
      "description": "Собираем правила внутри целого слова, затем читаем два и несколько слов подряд."
    }
  ],
  "lessons": [
    {
      "id": "read-01",
      "order": 1,
      "moduleId": "short-patterns",
      "prerequisites": [],
      "title": "Самые короткие соответствия",
      "target": "a · i/y · u · ou",
      "goal": "Увидеть одну букву или короткое сочетание и сразу назвать основной звук.",
      "focus": ["a → [a]", "i/y → [i]", "u → [y]", "ou → [u]"],
      "rule": "Сначала ищи знакомое сочетание целиком. В слове loup сочетание ou читается как один звук [u], а не как отдельные o и u.",
      "spellings": [
        { "pattern": "a, à, â", "sound": "[a]", "examples": "ami, là, âge", "soundText": "a, à, â" },
        { "pattern": "i, y, ï, î", "sound": "[i]", "examples": "il, type, naïf, île", "soundText": "i, y, ï, î" },
        { "pattern": "u, û", "sound": "[y]", "examples": "tu, du, sûr", "soundText": "u, û" },
        { "pattern": "ou, où, oû, aou, aoû", "sound": "[u]", "examples": "loup, où, croûte, saoul, août", "soundText": "ou, où, oû, aou, aoû" }
      ],
      "examples": [
        { "text": "ami", "ipa": "[ami]", "note": "a даёт [a], i даёт [i]." },
        { "text": "tu", "ipa": "[ty]", "note": "Одиночная u даёт [y]." },
        { "text": "loup", "ipa": "[lu]", "note": "ou читается одним звуком [u], конечная p не слышна." },
        { "text": "saoul", "ipa": "[su]", "note": "Редкое написание aou тоже даёт [u]." },
        { "text": "août", "ipa": "[u]", "note": "Несколько букв могут передавать один звук." }
      ],
      "practice": [
        "Назови звук: a, i, u, ou.",
        "Найди знакомые части в ami, tu и loup.",
        "Прочитай слова, затем проверь каждое по аудио."
      ],
      "cards": [
        { "id": "pron-atom:01:a", "kind": "pattern", "prompt": "Как читается a в ami?", "answer": "[a] — ami", "audioText": "ami", "explanation": "Одна карточка проверяет только написание a." },
        { "id": "pron-atom:01:a-grave", "kind": "pattern", "prompt": "Как читается à в là?", "answer": "[a] — là", "audioText": "là", "explanation": "Accent grave не меняет звук этой буквы." },
        { "id": "pron-atom:01:a-circ", "kind": "pattern", "prompt": "Как читается â в âge?", "answer": "[a] — âge", "audioText": "âge", "explanation": "Карточка проверяет â отдельно от a и à." },
        { "id": "pron-atom:01:i", "kind": "pattern", "prompt": "Как читается i в il?", "answer": "[i] — il", "audioText": "il", "explanation": "Одиночная i обычно даёт [i]." },
        { "id": "pron-atom:01:y", "kind": "pattern", "prompt": "Как читается y в type?", "answer": "[i] — type", "audioText": "type", "explanation": "Здесь y передаёт тот же звук [i], но проверяется отдельно." },
        { "id": "pron-atom:01:i-diaeresis", "kind": "pattern", "prompt": "Как читается ï в naïf?", "answer": "[i] — naïf", "audioText": "naïf", "explanation": "Трема показывает, что ï читается отдельно от соседней гласной." },
        { "id": "pron-atom:01:i-circ", "kind": "pattern", "prompt": "Как читается î в île?", "answer": "[i] — île", "audioText": "île", "explanation": "Написание î проверяется отдельной карточкой." },
        { "id": "pron-atom:01:u", "kind": "pattern", "prompt": "Как читается u в tu?", "answer": "[y] — tu", "audioText": "tu", "explanation": "Не путай одиночную u [y] с сочетанием ou [u]." },
        { "id": "pron-atom:01:u-circ", "kind": "pattern", "prompt": "Как читается û в sûr?", "answer": "[y] — sûr", "audioText": "sûr", "explanation": "Это карточка для французской û; буква ú в базовой орфографии не используется." },
        { "id": "pron-atom:01:ou", "kind": "pattern", "prompt": "Как читается ou в loup?", "answer": "[u] — loup", "audioText": "loup", "explanation": "Две буквы ou образуют один звук [u]." },
        { "id": "pron-atom:01:ou-grave", "kind": "pattern", "prompt": "Как читается où?", "answer": "[u] — où", "audioText": "où", "explanation": "Написание où проверяется отдельно от ou." },
        { "id": "pron-atom:01:ou-circ", "kind": "pattern", "prompt": "Как читается oû в croûte?", "answer": "[u] — croûte", "audioText": "croûte", "explanation": "Написание oû даёт один звук [u]." },
        { "id": "pron-atom:01:aou", "kind": "pattern", "prompt": "Как читается aou в saoul?", "answer": "[u] — saoul", "audioText": "saoul", "explanation": "Редкое aou проверяется собственной карточкой." },
        { "id": "pron-atom:01:aou-circ", "kind": "pattern", "prompt": "Как читается aoû в août?", "answer": "[u] — août", "audioText": "août", "explanation": "Несколько букв aoû передают один звук [u]." },
        { "id": "pron-word:01:loup", "kind": "word", "prompt": "Прочитай слово loup целиком.", "answer": "l-ou-p → [lu]", "audioText": "loup", "explanation": "Это дополнительная сборочная карточка после отдельной карточки ou." },
        { "id": "pron-word:01:aout", "kind": "word", "prompt": "Прочитай слово août целиком.", "answer": "aoû-t → [u]", "audioText": "août", "explanation": "Это дополнительная сборочная карточка после отдельной карточки aoû." }
      ]
    },
    {
      "id": "read-02",
      "order": 2,
      "moduleId": "short-patterns",
      "prerequisites": ["read-01"],
      "title": "Сочетания гласных",
      "target": "é/er/ez · e/è/ê/ai/ei · o/au/eau · oi · ui · eu/œu",
      "goal": "Читать частые двух- и трёхбуквенные сочетания гласных как единый блок.",
      "focus": ["é/-er/-ez/et → [e]", "ai/ei → [ɛ]", "e → [ə] или [ɛ]", "o → [o] или [ɔ]", "eau → [o]"],
      "rule": "Если несколько гласных стоят рядом, сначала проверь знакомое сочетание. Не раскладывай eau, oi или ai на отдельные буквы. Обычные e и o зависят от позиции, поэтому их нужно проверять внутри слога.",
      "spellings": [
        { "pattern": "é, -er, -ez, et (слово)", "sound": "[e]", "examples": "café, parler, nez, et", "soundText": "é, er, ez, et" },
        { "pattern": "è, ê, ai, aî, ei, est, -et, ey", "sound": "обычно [ɛ]", "examples": "père, pêche, lait, seize, est, effet, volley", "soundText": "è, ê, ai, aî, ei, est, et, ey" },
        { "pattern": "e без акцента", "sound": "[ə] или [ɛ] по позиции", "examples": "le, petit, sel", "soundText": "e" },
        { "pattern": "o", "sound": "[o] или [ɔ] по позиции", "examples": "moto, porte", "soundText": "o" },
        { "pattern": "au, eau, ô", "sound": "[o]", "examples": "auto, bateau, dépôt", "soundText": "au, eau, ô" },
        { "pattern": "oi, oî", "sound": "[wa]", "examples": "trois, cloître", "soundText": "oi, oî" },
        { "pattern": "ui, uî", "sound": "[ɥi]", "examples": "lui, huître", "soundText": "ui, uî" },
        { "pattern": "eu, œu", "sound": "[ø] или [œ]", "examples": "feu, nœud, neuf", "soundText": "eu, œu" }
      ],
      "examples": [
        { "text": "café", "ipa": "[kafe]", "note": "é читается [e]." },
        { "text": "et", "ipa": "[e]", "note": "Отдельное слово et читается [e]." },
        { "text": "effet", "ipa": "[efɛ]", "note": "Финальное -et здесь даёт [ɛ], поэтому et и -et нельзя смешивать." },
        { "text": "le", "ipa": "[lə]", "note": "Безударная e здесь даёт [ə]." },
        { "text": "lait", "ipa": "[lɛ]", "note": "ai читается [ɛ], конечные t не слышно." },
        { "text": "porte", "ipa": "[pɔʁt]", "note": "Обычная o в закрытом слоге даёт [ɔ]." },
        { "text": "bateau", "ipa": "[bato]", "note": "eau читается как один звук [o]." },
        { "text": "trois", "ipa": "[tʁwa]", "note": "oi даёт [wa]." },
        { "text": "lui", "ipa": "[lɥi]", "note": "ui даёт быстрое [ɥi]." }
      ],
      "practice": [
        "Подчеркни сочетания в café, lait, bateau, trois и lui.",
        "Сравни et/effet и moto/porte: одинаковая буква не всегда даёт одинаковый звук.",
        "Замени каждое подчёркнутое сочетание его звуком.",
        "Собери слово целиком и проверь аудио."
      ],
      "cards": [
        { "id": "pron-atom:02:e-acute", "kind": "pattern", "prompt": "Как читается é в café?", "answer": "[e] — café", "audioText": "café", "explanation": "Accent aigu é обычно указывает на [e]." },
        { "id": "pron-atom:02:er", "kind": "pattern", "prompt": "Как читается конечное -er в parler?", "answer": "[e] — parler", "audioText": "parler", "explanation": "Карточка проверяет только окончание -er." },
        { "id": "pron-atom:02:ez", "kind": "pattern", "prompt": "Как читается конечное -ez в nez?", "answer": "[e] — nez", "audioText": "nez", "explanation": "Карточка проверяет только окончание -ez." },
        { "id": "pron-atom:02:et-word", "kind": "pattern", "prompt": "Как читается отдельное слово et?", "answer": "[e] — et", "audioText": "et", "explanation": "Не смешивай слово et [e] с окончанием -et [ɛ]." },
        { "id": "pron-atom:02:e-grave", "kind": "pattern", "prompt": "Как читается è в père?", "answer": "[ɛ] — père", "audioText": "père", "explanation": "Accent grave è указывает на [ɛ]." },
        { "id": "pron-atom:02:e-circ", "kind": "pattern", "prompt": "Как читается ê в pêche?", "answer": "[ɛ] — pêche", "audioText": "pêche", "explanation": "Написание ê проверяется отдельно от è." },
        { "id": "pron-atom:02:ai", "kind": "pattern", "prompt": "Как читается ai в lait?", "answer": "[ɛ] — lait", "audioText": "lait", "explanation": "Сочетание ai даёт один звук [ɛ]." },
        { "id": "pron-atom:02:ai-circ", "kind": "pattern", "prompt": "Как читается aî в maître?", "answer": "[ɛ] — maître", "audioText": "maître", "explanation": "Написание aî проверяется своей карточкой." },
        { "id": "pron-atom:02:ei", "kind": "pattern", "prompt": "Как читается ei в seize?", "answer": "[ɛ] — seize", "audioText": "seize", "explanation": "Сочетание ei читается одним звуком [ɛ]." },
        { "id": "pron-atom:02:est", "kind": "pattern", "prompt": "Как читается est?", "answer": "[ɛ] — est", "audioText": "est", "explanation": "Форма est проверяется отдельно от слова et." },
        { "id": "pron-atom:02:et-ending", "kind": "pattern", "prompt": "Как читается окончание -et в effet?", "answer": "[ɛ] — effet", "audioText": "effet", "explanation": "Окончание -et здесь не равно слову et [e]." },
        { "id": "pron-atom:02:ey", "kind": "pattern", "prompt": "Как читается ey в volley?", "answer": "[ɛ] — volley", "audioText": "volley", "explanation": "Редкое ey проверяется отдельно." },
        { "id": "pron-atom:02:e-schwa", "kind": "rule", "prompt": "Как читается e в слове le?", "answer": "[ə] — le", "audioText": "le", "explanation": "Контекст слова закреплён прямо на карточке." },
        { "id": "pron-atom:02:e-open", "kind": "rule", "prompt": "Как читается e в закрытом слоге sel?", "answer": "[ɛ] — sel", "audioText": "sel", "explanation": "Та же буква e в другом контексте проверяется отдельной карточкой." },
        { "id": "pron-atom:02:o-closed", "kind": "rule", "prompt": "Как читается o в moto?", "answer": "[o] — moto", "audioText": "moto", "explanation": "Карточка закрепляет закрытый [o] в конкретном слове." },
        { "id": "pron-atom:02:o-open", "kind": "rule", "prompt": "Как читается o в porte?", "answer": "[ɔ] — porte", "audioText": "porte", "explanation": "Открытый [ɔ] проверяется отдельно от [o] в moto." },
        { "id": "pron-atom:02:au", "kind": "pattern", "prompt": "Как читается au в auto?", "answer": "[o] — auto", "audioText": "auto", "explanation": "Сочетание au образует один звук [o]." },
        { "id": "pron-atom:02:eau", "kind": "pattern", "prompt": "Как читается eau в bateau?", "answer": "[o] — bateau", "audioText": "bateau", "explanation": "Три буквы eau передают один звук [o]." },
        { "id": "pron-atom:02:o-circ", "kind": "pattern", "prompt": "Как читается ô в dépôt?", "answer": "[o] — dépôt", "audioText": "dépôt", "explanation": "Написание ô проверяется отдельно." },
        { "id": "pron-atom:02:oi", "kind": "pattern", "prompt": "Как читается oi в trois?", "answer": "[wa] — trois", "audioText": "trois", "explanation": "Сочетание oi читается целиком." },
        { "id": "pron-atom:02:oi-circ", "kind": "pattern", "prompt": "Как читается oî в cloître?", "answer": "[wa] — cloître", "audioText": "cloître", "explanation": "Написание oî проверяется отдельно от oi." },
        { "id": "pron-atom:02:ui", "kind": "pattern", "prompt": "Как читается ui в lui?", "answer": "[ɥi] — lui", "audioText": "lui", "explanation": "Сочетание ui образует [ɥi]." },
        { "id": "pron-atom:02:ui-circ", "kind": "pattern", "prompt": "Как читается uî в huître?", "answer": "[ɥi] — huître", "audioText": "huître", "explanation": "Написание uî проверяется собственной карточкой." },
        { "id": "pron-atom:02:eu-closed", "kind": "rule", "prompt": "Как читается eu в feu?", "answer": "[ø] — feu", "audioText": "feu", "explanation": "Контекст feu закрепляет закрытый вариант [ø]." },
        { "id": "pron-atom:02:eu-open", "kind": "rule", "prompt": "Как читается eu в neuf?", "answer": "[œ] — neuf", "audioText": "neuf", "explanation": "Контекст neuf закрепляет открытый вариант [œ]." },
        { "id": "pron-atom:02:oeu-closed", "kind": "rule", "prompt": "Как читается œu в nœud?", "answer": "[ø] — nœud", "audioText": "nœud", "explanation": "Сочетание œu здесь даёт [ø]." },
        { "id": "pron-atom:02:oeu-open", "kind": "rule", "prompt": "Как читается œu в cœur?", "answer": "[œ] — cœur", "audioText": "cœur", "explanation": "Сочетание œu здесь даёт [œ] и проверяется отдельно." },
        { "id": "pron-word:02:bateau", "kind": "word", "prompt": "Прочитай слово bateau целиком.", "answer": "bat-eau → [bato]", "audioText": "bateau", "explanation": "Сборочная карточка не заменяет отдельную карточку eau." }
      ]
    },
    {
      "id": "read-03",
      "order": 3,
      "moduleId": "short-patterns",
      "prerequisites": ["read-02"],
      "title": "Сочетания согласных",
      "target": "ch · ph · gn · qu · gu · il/ill",
      "goal": "Узнавать согласные блоки, которые нельзя читать буква за буквой.",
      "focus": ["ch → [ʃ]", "ph → [f]", "gn → [ɲ]", "qu → [k]", "ill → [j]"],
      "rule": "Сначала выдели устойчивый согласный блок. ch, ph, gn и qu обычно передают один согласный звук; gu сохраняет твёрдый [g] перед e, i и y.",
      "spellings": [
        { "pattern": "ch", "sound": "[ʃ]", "examples": "chat, vache, poche", "soundText": "ch" },
        { "pattern": "ph", "sound": "[f]", "examples": "photo", "soundText": "ph" },
        { "pattern": "gn", "sound": "[ɲ]", "examples": "ligne", "soundText": "gn" },
        { "pattern": "qu", "sound": "[k]", "examples": "qui", "soundText": "qu" },
        { "pattern": "gu + e/i/y", "sound": "[g]", "examples": "guitare, guerre", "soundText": "gu" },
        { "pattern": "il, ill", "sound": "часто [j]", "examples": "travail, travailler, feuille", "soundText": "il, ill" }
      ],
      "examples": [
        { "text": "chat", "ipa": "[ʃa]", "note": "ch даёт [ʃ], конечная t не слышна." },
        { "text": "photo", "ipa": "[foto]", "note": "ph даёт [f]." },
        { "text": "ligne", "ipa": "[liɲ]", "note": "gn даёт один мягкий звук [ɲ]." },
        { "text": "qui", "ipa": "[ki]", "note": "qu читается [k]." },
        { "text": "travail", "ipa": "[tʁavaj]", "note": "Финальное il здесь даёт [j]." }
      ],
      "practice": [
        "Выдели согласный блок в chat, photo, ligne, qui и travail.",
        "Назови звук блока, не читая его по буквам.",
        "Добавь остальные части слова и проверь результат."
      ],
      "cards": [
        { "id": "pron-atom:03:ch", "kind": "pattern", "prompt": "Как читается ch в vache?", "answer": "[ʃ] — vache", "audioText": "vache", "explanation": "Карточка проверяет обычное чтение ch; technique будет отдельным исключением." },
        { "id": "pron-atom:03:ph", "kind": "pattern", "prompt": "Как читается ph?", "answer": "[f] — photo", "audioText": "photo", "explanation": "Две буквы передают один согласный [f]." },
        { "id": "pron-atom:03:gn", "kind": "pattern", "prompt": "Как читается gn?", "answer": "[ɲ] — ligne", "audioText": "ligne", "explanation": "Не произноси отдельные [g] и [n]." },
        { "id": "pron-atom:03:qu", "kind": "pattern", "prompt": "Как читается qu?", "answer": "[k] — qui", "audioText": "qui", "explanation": "Буква u внутри qu отдельно не звучит." },
        { "id": "pron-atom:03:gu", "kind": "rule", "prompt": "Как читается gu перед i в guitare?", "answer": "[g] — guitare", "audioText": "guitare", "explanation": "u сохраняет твёрдый [g] и отдельно не произносится." },
        { "id": "pron-atom:03:il", "kind": "pattern", "prompt": "Как читается финальное il в travail?", "answer": "[j] — travail", "audioText": "travail", "explanation": "Написание il проверяется отдельно от ill." },
        { "id": "pron-atom:03:ill", "kind": "pattern", "prompt": "Как читается ill в travailler?", "answer": "[j] — travailler", "audioText": "travailler", "explanation": "Исключения ville, mille и tranquille будут отдельными карточками." }
      ]
    },
    {
      "id": "read-04",
      "order": 4,
      "moduleId": "context-rules",
      "prerequisites": ["read-03"],
      "title": "Смотрим на соседнюю букву",
